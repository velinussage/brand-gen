# Copy this file to .env and fill in the values you actually use.
# The local repo .env is checked first, then ~/.claude/.env as a fallback.

# Required for any Replicate-powered generation
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# Optional: local browser automation defaults
AGENT_BROWSER_SESSION=brand-gen
# Optional when multiple agent-browser installs exist
# AGENT_BROWSER_BIN=/full/path/to/agent-browser

# Optional: use remote Browserbase sessions instead of local Chromium
# AGENT_BROWSER_PROVIDER=browserbase
# BROWSERBASE_API_KEY=...
# BROWSERBASE_PROJECT_ID=...

# Optional: default workspace root for generated assets
# SCREENSHOTS_DIR=$HOME/brand-projects/acme
# LOGO_DIR=$HOME/brand-projects/acme/logo-redesigns   # legacy compatibility only

# Optional default output directory for generated brand materials
# BRAND_DIR=$HOME/brand-projects/acme/brand-materials
